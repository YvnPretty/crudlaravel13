        "APP_KEY": "base64:PcjoMj+t46qoTr7vVTQxRsg45ygn8zMTWRLe4C/4Sb0=",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": "/tmp/database.sqlite",
